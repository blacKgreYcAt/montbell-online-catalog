# 生產環境配置示例
# 注意：這些變數應該在 Vercel 儀表板中設置，而不是在 .env.production 文件中

# Google Drive 配置
GOOGLE_DRIVE_FOLDER_ID=your_production_folder_id

# Cron Job 認證密鑰（務必使用強密鑰）
CRON_SECRET=your-production-secret-key-min-32-chars-long

# Google Cloud 服務帳戶 JSON
# 複製整個 JSON 內容
GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}

# 網站 URL（設為你的 Vercel 域名）
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
