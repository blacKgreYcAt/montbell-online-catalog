# Montbell Online Catalog - 環境變數範本
# 複製此檔案為 .env.local 並填入實際值

# ============================================
# 網站配置
# ============================================

# 網站 URL (用於 SEO 和分享)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# Montbell CDN 圖片配置 (優先級：第一位)
# ============================================

# CDN 基礎 URL
# ✅ 日本官網 (已確認): https://www.montbell.com/storage/products/images/origin
# 台灣官網: https://tw.montbell.com/images/product (如有)
# 自訂 CDN: https://res.cloudinary.com/montbell/image/upload
NEXT_PUBLIC_MONTBELL_CDN_URL=https://www.montbell.com/storage/products/images/origin

# URL 模式語法：
#   {model}  = 型號 (自動轉換為 7 位數字)
#   {color}  = 顏色代碼 (自動轉換為小寫)
#
# ✅ 日本官網 (已確認):
#   {model}_{color}.webp → 1128573_rbl.webp
#
# 其他範例：
#   {model}_{color}.jpg  → 1128573_rbl.jpg
#   {model}-{color}.jpg  → 1128573-rbl.jpg
NEXT_PUBLIC_MONTBELL_URL_PATTERN={model}_{color}.webp

# 是否啟用 Montbell CDN (true/false)
# 設為 false 時會自動降級至 Google Drive
NEXT_PUBLIC_MONTBELL_CDN_ENABLED=true

# ============================================
# Google Drive 備份配置 (優先級：第二位)
# ============================================

# Google Drive API 金鑰
# 只有在需要備份圖片時才需要設定
NEXT_PUBLIC_GOOGLE_DRIVE_API_KEY=

# Google Drive 資料夾 ID
GOOGLE_DRIVE_FOLDER_ID=

# ============================================
# Cron Job 配置 (用於定期更新)
# ============================================

# Cron Job 密鑰 (用於安全驗證排程任務)
CRON_SECRET=your-secret-key-here

# ============================================
# 部署配置
# ============================================

# 僅用於 Vercel 部署的環境變數
# 無需在本地設定

# ============================================
# 開發工具配置 (選擇性)
# ============================================

# Montbell CDN 測試工具使用
# 可透過以下命令測試：
#   python test_montbell_cdn.py 1128573 RBL
#   python test_montbell_cdn.py --test-all --limit 100

# 自訂測試 URL (可選)
# MONTBELL_CDN_URL=https://image.montbell.com/product
# MONTBELL_URL_PATTERN={model}_{color}.jpg

# ============================================
# 設定說明
# ============================================

# 1. 本地開發 (.env.local)
#    複製此檔案為 .env.local，填入您的設定
#    npm run dev

# 2. Vercel 部署 (Vercel Dashboard)
#    登入 Vercel Dashboard
#    → Settings → Environment Variables
#    新增上述變數並值

# 3. 環境變數優先級：
#    .env.local > .env.production > .env > 預設值

# 4. 重要事項：
#    - 將 .env.local 加入 .gitignore
#    - 不要提交包含敏感信息的環境變數到 Git
#    - API 金鑰應該只在 Vercel 或 .env.local 中設定
